{
  "name": "Movie-Reservation-System",
  "version": "1.0.0",
  "description": "A backend system for a movie reservation service. The service will allow users to sign up, log in, browse movies, reserve seats for specific showtimes, and manage their reservations. The system will feature user authentication, movie and showtime management, seat reservation functionality, and reporting on reservations.",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src/ --fix",
    "dev": "ts-node-dev --respawn   --require tsconfig-paths/register src/server.ts ",
    "build": "tsc  && tsc-alias ",
    "start": "node   dist/server.js",
    "seed": "ts-node   --require tsconfig-paths/register src/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boss-moh/Movie-Reservation-System.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/boss-moh/Movie-Reservation-System/issues"
  },
  "homepage": "https://github.com/boss-moh/Movie-Reservation-System#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "tsc-alias": "^1.8.16",
    "vitest": "^4.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "install": "^0.13.0",
    "npm": "^11.12.1",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.3",
    "vitest-mock-extended": "^4.0.0"
  }
}